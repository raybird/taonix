{
  "name": "taonix",
  "version": "27.0.0",
  "description": "Taonix AI task runtime",
  "type": "module",
  "main": "src/index.js",
  "exports": {
    ".": "./src/index.js",
    "./runtime": "./src/core/runtime/index.js",
    "./cli": "./src/interfaces/cli/index.js",
    "./mcp": "./src/interfaces/mcp/index.js",
    "./mcp-stdio": "./src/interfaces/mcp/stdio.js"
  },
  "bin": {
    "taonix": "./src/interfaces/cli/index.js",
    "taonix-mcp": "./src/interfaces/mcp/stdio.js"
  },
  "files": [
    "src/",
    "CLAUDE.md",
    "MANIFEST.json",
    "README.md",
    "docs/README.md",
    "docs/AGENTS.md",
    "docs/SOP.md",
    "docs/migration/"
  ],
  "scripts": {
    "start": "node src/interfaces/mcp/stdio.js",
    "cli": "node src/interfaces/cli/index.js",
    "test": "node --test tests/contracts/*.test.js tests/runtime/*.test.js tests/capabilities/*.test.js tests/integration/*.test.js tests/e2e/*.test.js",
    "runtime": "node src/interfaces/cli/index.js run"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "keywords": [
    "taonix",
    "mcp",
    "runtime",
    "ai"
  ],
  "author": "Taonix Team",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^0.5.0",
    "commander": "^12.0.0"
  }
}
