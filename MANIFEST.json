{
  "system": "Taonix AI Task Runtime",
  "version": "27.0.0",
  "philosophy": "單一 runtime 入口、穩定 task/result 契約、runtime-first execution。",
  "requirements": {
    "node": ">=22.0.0",
    "module_system": "ESM"
  },
  "entry_points": {
    "cli": "src/interfaces/cli/index.js",
    "mcp": "src/interfaces/mcp/stdio.js",
    "runtime": "src/core/runtime/index.js"
  },
  "quickstart": {
    "install": "npm install",
    "verify": "npm test",
    "start_mcp": "node src/interfaces/mcp/stdio.js",
    "start_runtime": "node src/interfaces/cli/index.js run \"你的意圖指令\"",
    "start_cli": "node src/interfaces/cli/index.js capabilities",
    "test": "npm test"
  },
  "capabilities": [
    {
      "name": "taonix_hub",
      "type": "unified_entry",
      "description": "接收自然語言或結構化 task，統一委派至 runtime pipeline。",
      "mcp_tool": "taonix_hub",
      "input_schema": {
        "type": "object",
        "properties": {
          "intent": {
            "type": "string",
            "description": "任務意圖（自然語言）"
          },
          "task": {
            "type": "object",
            "description": "正式 TaskSpec 輸入"
          }
        }
      }
    },
    {
      "name": "analyze_structure",
      "type": "capability",
      "execution_mode": "in_process"
    },
    {
      "name": "check_quality",
      "type": "capability",
      "execution_mode": "in_process"
    },
    {
      "name": "web_search",
      "type": "capability",
      "execution_mode": "in_process"
    },
    {
      "name": "github_trending",
      "type": "capability",
      "execution_mode": "in_process"
    }
  ],
  "internal_agents": [],
  "skills": [],
  "directory_structure": {
    "src/core/contracts/": "正式 task/result/capability/event 契約",
    "src/core/runtime/": "router / dispatcher / executor / child protocol",
    "src/core/plugins/": "capability registry 與 loader",
    "src/core/telemetry/": "task log / trace log / event sink",
    "src/capabilities/": "顯式 capability modules",
    "src/interfaces/": "CLI 與 MCP 薄介面",
    "docs/": "技術文件與變更紀錄",
    "tests/": "contracts/runtime/capabilities/integration/e2e 測試"
  },
  "environment_variables": {
    "TAONIX_DATA_DIR": "資料存放根目錄（預設為專案目錄）",
    "TAONIX_AI_PROVIDER": "AI CLI provider（opencode / gemini / codex / ollama）",
    "TAONIX_AI_MODEL": "AI model 名稱（依 provider 而定）"
  },
  "protocols": {
    "task_contract": "TaskSpec / ResultSpec",
    "routing": "deterministic router with optional classifier",
    "execution": "in-process first, child-process fallback",
    "telemetry": "replaceable event sink"
  }
}
